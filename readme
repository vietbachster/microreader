#### build ui font
python tools/generate_font.py resources/fonts/Terminus-Bold.ttf 14 -o resources/fonts/ui-small.mbf --header lib/microreader/display/ui_font_small.h --bw-only

#### build reader font
python tools/generate_font.py "resources/fonts/bookerly/Bookerly.ttf" -o resources/fonts/bookerly.mfb --with-styles --bold "resources/fonts/bookerly/Bookerly Bold.ttf" --italic "resources/fonts/bookerly/Bookerly Italic.ttf" --bold-italic "resources/fonts/bookerly/Bookerly Bold Italic.ttf" --bundle --bundle-sizes 20 22 24 26 28 30 32 --font-name Bookerly
python tools/generate_font.py "resources/fonts/alegreya/Alegreya-Medium.ttf" -o resources/fonts/alegreya.mfb --with-styles --bold "resources/fonts/alegreya/Alegreya-Bold.ttf" --italic "resources/fonts/alegreya/Alegreya-MediumItalic.ttf" --bold-italic "resources/fonts/alegreya/Alegreya-BoldItalic.ttf" --bundle --bundle-sizes 20 22 24 26 28 30 32 --font-name Alegreya

#### upload font
python .\tools\serial_cmd.py --upload-font .\resources\fonts\bookerly.mfb
python tools/serial_cmd.py --upload-sd-font .\resources\fonts\alegreya.mfb

#### convert sleep screen
python .\tools\image_to_mgr.py "resources/sleep/sleep_2.jpg" --out-prefix "resources/sleep/sleep_2" --bin
python tools/serial_cmd.py --upload-sleep "C:\Users\Patrick\Desktop\microreader\microreader2\resources\sleep.mgr"
python tools/serial_cmd.py --clear-sleep

#### selecting boot partition
python -m esptool --port COM4 write_flash 0xE000 otadata_boot_app0.bin
python -m esptool --port COM4 write_flash 0x10000 app0_backup.bin